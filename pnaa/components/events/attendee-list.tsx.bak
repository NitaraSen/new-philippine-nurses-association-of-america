"use client";

import { useState, useEffect, useRef, useMemo } from "react";
import {
  collection,
  query,
  onSnapshot,
  type Unsubscribe,
} from "firebase/firestore";
import { db } from "@/lib/firebase/config";
import { AdvancedDataTable, type ColumnDef, type ColumnMeta } from "@/components/shared/advanced-data-table";
import { Badge } from "@/components/ui/badge";
import { Users } from "lucide-react";
import type { AppEvent as Attendee } from "@/types/attendee";

type AttendeeRow = Attendee & { id: string };

export function AttendeeList({ eventId }: { eventId: string }) {
  const [rows, setRows] = useState<AttendeeRow[]>([]);
  const [loading, setLoading] = useState(true);
  // Keep a ref to the active unsubscribe fn so strict-mode double-invoke
  // cancels the first listener before starting a second one.
  const unsubscribeRef = useRef<Unsubscribe | null>(null);

  useEffect(() => {
    // Cancel any existing listener before starting a new one
    unsubscribeRef.current?.();

    const q = query(collection(db, "events", eventId, "attendees"));

    const unsubscribe = onSnapshot(
      q,
      (snapshot) => {
        setRows(
          snapshot.docs.map((doc) => ({ ...doc.data(), id: doc.id }) as AttendeeRow)
        );
        setLoading(false);
      },
      () => setLoading(false)
    );

    unsubscribeRef.current = unsubscribe;
    return () => {
      unsubscribe();
      unsubscribeRef.current = null;
    };
  }, [eventId]);

  // Map registrationId -> name for resolving guest names
  const registrationNames = useMemo(() => {
    const map = new Map<string, string>();
    for (const row of rows) {
      map.set(row.registrationId, row.name);
    }
    return map;
  }, [rows]);

  const columns: ColumnDef<AttendeeRow, unknown>[] = useMemo(
    () => [
      {
        accessorKey: "name",
        header: "Name",
        size: 200,
        enableSorting: true,
        meta: { filterType: "text" } satisfies ColumnMeta,
        cell: ({ row }) => (
          <span className="font-medium text-sm">{row.original.name || "—"}</span>
        ),
      },
      {
        accessorKey: "registrationFee",
        header: "Fee",
        size: 90,
        enableSorting: true,
        cell: ({ row }) => (
          <span className="tabular-nums text-sm">
            {row.original.registrationFee != null
              ? `$${row.original.registrationFee.toFixed(2)}`
              : "—"}
          </span>
        ),
      },
      {
        accessorKey: "paidSum",
        header: "Paid",
        size: 90,
        enableSorting: true,
        cell: ({ row }) => (
          <span className="tabular-nums text-sm">
            {row.original.paidSum != null
              ? `$${row.original.paidSum.toFixed(2)}`
              : "—"}
          </span>
        ),
      },
      {
        accessorKey: "isPaid",
        header: "Fully Paid",
        size: 100,
        enableSorting: true,
        filterFn: "equals",
        meta: {
          filterType: "select",
          filterOptions: [
            { label: "Yes", value: "true" },
            { label: "No", value: "false" },
          ],
        } satisfies ColumnMeta,
        accessorFn: (row) => String(row.isPaid),
        cell: ({ row }) =>
          row.original.isPaid ? (
            <Badge variant="outline" className="text-xs text-green-700 border-green-200 bg-green-50 dark:bg-green-950/30">
              Yes
            </Badge>
          ) : (
            <Badge variant="outline" className="text-xs text-amber-700 border-amber-200 bg-amber-50 dark:bg-amber-950/30">
              No
            </Badge>
          ),
      },
      {
        accessorKey: "Status",
        header: "Status",
        size: 130,
        enableSorting: true,
        meta: { filterType: "text" } satisfies ColumnMeta,
        cell: ({ row }) => (
          <span className="text-sm text-muted-foreground">
            {row.original.Status || "—"}
          </span>
        ),
      },
      {
        id: "guests",
        header: "Guests",
        size: 240,
        enableSorting: false,
        accessorFn: (row) => String(row.guestIds?.length ?? 0),
        cell: ({ row }) => {
          const guestIds = row.original.guestIds;
          if (!guestIds?.length) {
            return <span className="text-xs text-muted-foreground/50">—</span>;
          }
          const names = guestIds.map((id) => registrationNames.get(id) ?? id);
          return (
            <span className="text-xs text-muted-foreground">{names.join(", ")}</span>
          );
        },
      },
    ],
    [registrationNames]
  );

  return (
    <AdvancedDataTable<AttendeeRow>
      columns={columns}
      data={rows}
      loading={loading}
      emptyTitle="No attendees"
      emptyDescription="No registrations found for this event"
      emptyIcon={Users}
      defaultPageSize={15}
      exportFilename={`PNAA_${eventId}_attendees`}
    />
  );
}
