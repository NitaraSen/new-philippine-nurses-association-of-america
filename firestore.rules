rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isNationalAdmin() {
      return getUserRole() == 'national_admin';
    }

    function isChapterAdmin() {
      return getUserRole() == 'chapter_admin';
    }

    function isAdmin() {
      return isNationalAdmin() || isChapterAdmin();
    }

    // Members: read-only for authenticated users
    match /members/{memberId} {
      allow read: if isAuthenticated();
      allow write: if false; // Cloud Functions only
    }

    // Chapters: read-only for authenticated users
    match /chapters/{chapterId} {
      allow read: if isAuthenticated();
      allow write: if false; // Cloud Functions only
    }

    // Events: read for authed, create/update for admins
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && isAdmin();
      allow delete: if false; // Soft delete only
    }

    // Fundraising: read for authed, create/update for admins
    match /fundraising/{campaignId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && isAdmin();
      allow delete: if false; // Soft delete only
    }

    // Users: read own profile or admin reads all
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isNationalAdmin());
      allow write: if false; // Cloud Functions / Admin SDK only
    }
  }
}
